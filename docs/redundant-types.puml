' ============================================================================
' AGENT ID TYPES (3 different ones!)
' ============================================================================

package "Agent Identity (REDUNDANT)" #da3633 {
  class "AgentId\n(background.rs)" as AgentId1 {
    inner: u64
    --
    Used for in-memory
    background tasks
  }
  
  class "AgentId\n(jfc-economy)" as AgentId2 {
    0: String
    --
    new_stable(prefix, idx)
    Used for solvers/validators
  }
  
  class "agent_id: String\n(swarm/types.rs)" as AgentId3 {
    (field on TeammateIdentity)
    --
    Used for teammates
  }
  
  class "task_id: String\n(BackgroundTask)" as TaskId {
    (field, not a type)
    --
    Yet another identifier
  }
}

note bottom of AgentId1
  **Problem**: No unified way to
  identify an agent across systems
end note

