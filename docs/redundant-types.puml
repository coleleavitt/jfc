' STATUS ENUMS (3 different ones!)
' ============================================================================

package "Agent Status (REDUNDANT)" #da3633 {
  enum "AgentStatus\n(background.rs)" as Status1 {
    Running
    Completed
    Failed(String)
  }
  
  enum "BackgroundAgentStatus\n(daemon/state.rs)" as Status2 {
    Pending
    Running
    Completed
    Failed
    Cancelled
  }
  
  enum "TeammateStatus\n(swarm/types.rs)" as Status3 {
    Running
    Idle
    Completed
    Failed
    Killed
  }
  
  enum "TaskLifecycle\n(types.rs)" as Status4 {
    Pending
