' ============================================================================
' PROPOSED UNIFIED
' ============================================================================

package "PROPOSED: Unified Agent Model" #238636 {
  class "AgentId\n(jfc-agent)" as UnifiedId <<unified>> #238636 {
    inner: Uuid
    --
    Single identity type
    everywhere
  }
  
  enum "AgentStatus\n(jfc-agent)" as UnifiedStatus <<unified>> #238636 {
    Pending
    Running
    Idle
    Completed
    Failed
    Cancelled
  }
  
  enum "AgentRole\n(jfc-agent)" as UnifiedRole <<unified>> #238636 {
    Solo
    Teammate
    Solver
    Validator
    Council
  }
  
  class "AgentState\n(jfc-agent)" as UnifiedState <<unified>> #238636 {
    id: AgentId
    status: AgentStatus
    role: AgentRole
    --
    description: String
    started_at: SystemTime
    completed_at: Option<SystemTime>
    error: Option<String>
    --
    token_count: u64
    tool_use_count: u32
    last_tool: Option<String>
    --
    // Role-specific (Option)
    team_name: Option<String>
    worktree_path: Option<PathBuf>
    trust_score: Option<i8>
    idle_reason: Option<String>
  }
  
  class "SpawnConfig\n(jfc-agent)" as UnifiedConfig <<unified>> #238636 {
    role: AgentRole
    prompt: String
    model: ModelId
    provider: Arc<dyn Provider>
    cwd: PathBuf
    --
    // Optional based on role
    team_name: Option<String>
    worktree_path: Option<PathBuf>
    max_tokens: Option<u64>
  }
  
  interface "AgentRegistry\n(jfc-agent)" as UnifiedRegistry <<unified>> #238636 {
    spawn(config: SpawnConfig) -> AgentId
    status(id: &AgentId) -> Option<AgentStatus>
    state(id: &AgentId) -> Option<AgentState>
    abort(id: &AgentId) -> bool
    complete(id: &AgentId, result: AgentResult)
    list() -> Vec<AgentState>
  }
  
  UnifiedState --> UnifiedId
  UnifiedState --> UnifiedStatus
  UnifiedState --> UnifiedRole
  UnifiedConfig --> UnifiedRole
  UnifiedRegistry --> UnifiedState
  UnifiedRegistry --> UnifiedConfig
}

