package "Agent State (REDUNDANT)" #da3633 {
  class "BackgroundTask\n(app.rs)" as BgTask {
    task_id: TaskId
    description: String
    status: TaskLifecycle
    started_at: Instant
    completed_at: Option<Instant>
    summary: Option<String>
    error: Option<String>
    tool_use_count: u32
    latest_input_tokens: u64
    cumulative_output_tokens: u64
    model_used: Option<String>
    messages: Vec<MessagePart>
    chat_messages: Vec<ChatMessage>
    --
    UI state for background agents
  }
  
  class "BackgroundAgentInfo\n(daemon/state.rs)" as BgInfo {
    id: String
    description: String
    status: BackgroundAgentStatus
    started_at: SystemTime
    completed_at: Option<SystemTime>
    summary: Option<String>
    error: Option<String>
    tool_use_count: u32
    latest_input_tokens: u64
    cumulative_output_tokens: u64
    model: Option<String>
    pid: Option<u32>
    log_path: PathBuf
    worktree_path: Option<PathBuf>
    --
    Persistent daemon state
  }
  
  class "InProcessTeammateState\n(swarm/types.rs)" as TeammateState {
    identity: TeammateIdentity
    task_id: String
    status: TeammateStatus
    prompt: String
    description: String
    model: Option<String>
    progress: TeammateProgress
    is_idle: bool
    shutdown_requested: bool
    started_at: Instant
    ended_at: Option<Instant>
    error: Option<String>
    abort_tx: watch::Sender<bool>
    --
    In-process teammate
  }
  
  class "TeammateInfo\n(swarm/types.rs)" as TeammateInfo {
    name: String
    agent_type: Option<String>
    spawned_at: Instant
    backend: BackendType
    abort_tx: Option<watch::Sender<bool>>
    --
    Summary in TeamContext
  }
}

BgTask .. BgInfo : "~90% same fields"
BgInfo .. TeammateState : "~70% same fields"
TeammateState .. TeammateInfo : "summarizes"

note bottom of BgTask
  **Problem**: Three structs tracking
  status, tokens, errors, timestamps
  for the same concept: "an agent"
end note

