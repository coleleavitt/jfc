package "ELIMINATED — Agent State (was 4 structs)" #da3633 {
  class "BackgroundTask\nengine/app.rs" as OldT1 #da3633 {
    task_id: String
    status: TaskLifecycle
    started_at: Instant
    messages: Vec<MessagePart>
